#!/bin/bash
# Shared pre-receive hook for git-push deploys.
# Symlinked into each bare repo's hooks/ directory.
# Builds the pushed code with Kaniko and rolls out the deployment.
# Runs BEFORE the ref is updated — a failed build rejects the push.

set -euo pipefail

# ── Config ─────────────────────────────────────────────────────
export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
# shellcheck source=/dev/null
source /home/deploy/.deploy.conf
export KUBECONFIG="/home/deploy/.kube/config"

APP_NAME=$(basename "$PWD" | sed 's/\.git$//')
SAFE_NAME=$(echo "$APP_NAME" | tr '.' '-')

# Prune this app's stale images (node + registry) after a successful rollout.
# Best-effort — runs via a narrow sudo grant and never fails the deploy.
prune_old_images() {
  echo ""
  echo "▶ Pruning old images..."
  sudo -n /usr/local/bin/cleanup-old-images "$REGISTRY" "$APP_NAME" "$TAG" 5 \
    || echo "⚠ Image cleanup skipped (non-fatal)"
}

# Validate app name — reject anything that could break paths or YAML
if [[ ! "$APP_NAME" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
  echo "✗ Invalid app name: ${APP_NAME}" >&2
  exit 1
fi

CONTEXT_DIR="/opt/build-contexts/${APP_NAME}"

# ── Read the push ──────────────────────────────────────────────
while read -r _oldrev newrev refname; do
  SHA="$newrev"
  REFNAME="$refname"
done

TAG="${SHA:0:7}"
IMAGE="${REGISTRY}/${APP_NAME}:${TAG}"
JOB_NAME="build-${SAFE_NAME}-${TAG}"

# Optional extra Kaniko flags (set in .deploy.conf), e.g. --skip-tls-verify for
# self-signed registries. Each becomes a 12-space-indented YAML list item with a
# trailing newline, so "${EXTRA_ARGS_YAML}volumeMounts:" lines up in the manifest
# below (empty adds nothing). Word-splitting is intentional — one item per flag.
KANIKO_EXTRA_ARGS="${KANIKO_EXTRA_ARGS:-}"
EXTRA_ARGS_YAML=""
for _arg in $KANIKO_EXTRA_ARGS; do
  EXTRA_ARGS_YAML+="            - \"${_arg}\""$'\n'
done

echo ""
echo "════════════════════════════════════════════════════"
echo "  Deploying ${APP_NAME} @ ${TAG}"
echo "════════════════════════════════════════════════════"
echo ""

# ── Extract code to build context ──────────────────────────────
echo "▶ Preparing build context..."
rm -rf "$CONTEXT_DIR"
mkdir -p "$CONTEXT_DIR"
git archive "$SHA" | tar -x -C "$CONTEXT_DIR"

# ── Optional per-app deploy config (monorepo support) ─────────
# A repo pushed to multiple app names (staging/prod, web/api, …) may carry a
# .deploy/<app-name>.conf per target that selects the build context, Dockerfile,
# Helm values file, build args and an allowed ref. Keys are parsed with a
# whitelist (never sourced), so pushed code cannot override hook config.
# Without a conf the hook behaves exactly as before.
BUILD_CONTEXT="."
DOCKERFILE="Dockerfile"
HELM_VALUES="helm-values.yaml"
BUILD_ARGS=""
ALLOWED_REF=""
APP_CONF="${CONTEXT_DIR}/.deploy/${APP_NAME}.conf"
if [ -f "$APP_CONF" ]; then
  echo "▶ Using deploy config: .deploy/${APP_NAME}.conf"
  conf() { sed -n "s/^$1=//p" "$APP_CONF" | tail -1 | sed -e "s/^[\"']//" -e "s/[\"']$//"; }
  BUILD_CONTEXT="$(conf BUILD_CONTEXT)";  BUILD_CONTEXT="${BUILD_CONTEXT:-.}"
  DOCKERFILE="$(conf DOCKERFILE)";        DOCKERFILE="${DOCKERFILE:-Dockerfile}"
  HELM_VALUES="$(conf HELM_VALUES)";      HELM_VALUES="${HELM_VALUES:-helm-values.yaml}"
  BUILD_ARGS="$(conf BUILD_ARGS)"
  ALLOWED_REF="$(conf ALLOWED_REF)"

  # Reject absolute paths and traversal in user-supplied paths
  for _p in "$BUILD_CONTEXT" "$DOCKERFILE" "$HELM_VALUES"; do
    case "$_p" in
      /*|*..*)
        echo "✗ Invalid path in .deploy/${APP_NAME}.conf: ${_p}" >&2
        rm -rf "$CONTEXT_DIR"
        exit 1
        ;;
    esac
  done

  # Guard: e.g. a prod app only accepts refs/heads/master
  if [ -n "$ALLOWED_REF" ] && [ "$REFNAME" != "$ALLOWED_REF" ]; then
    echo "✗ ${APP_NAME} only accepts pushes to ${ALLOWED_REF} (got ${REFNAME})." >&2
    rm -rf "$CONTEXT_DIR"
    exit 1
  fi

  if [ ! -d "${CONTEXT_DIR}/${BUILD_CONTEXT}" ]; then
    echo "✗ BUILD_CONTEXT '${BUILD_CONTEXT}' not found in pushed tree." >&2
    rm -rf "$CONTEXT_DIR"
    exit 1
  fi

  # Each KEY=VALUE becomes a Kaniko --build-arg (values must not contain
  # spaces). Word-splitting is intentional — one build arg per item.
  # shellcheck disable=SC2086
  for _ba in $BUILD_ARGS; do
    EXTRA_ARGS_YAML+="            - \"--build-arg=${_ba}\""$'\n'
  done
fi

# ── Clean up previous build job ────────────────────────────────
kubectl delete job "$JOB_NAME" --ignore-not-found -n "$NAMESPACE" 2>&1 || true

# ── Create Kaniko build job ────────────────────────────────────
echo "▶ Creating build job..."
cat <<EOF | kubectl apply -f - 2>&1
apiVersion: batch/v1
kind: Job
metadata:
  name: ${JOB_NAME}
  namespace: ${NAMESPACE}
  labels:
    app: build
    target: ${SAFE_NAME}
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 300
  template:
    spec:
      containers:
        - name: kaniko
          image: gcr.io/kaniko-project/executor:latest
          args:
            - "--dockerfile=${DOCKERFILE}"
            - "--context=dir:///workspace/${BUILD_CONTEXT}"
            - "--destination=${IMAGE}"
            - "--destination=${REGISTRY}/${APP_NAME}:latest"
            - "--cache=true"
            - "--cache-repo=${REGISTRY}/${APP_NAME}/cache"
${EXTRA_ARGS_YAML}          volumeMounts:
            - name: build-context
              mountPath: /workspace
              readOnly: true
            - name: docker-config
              mountPath: /kaniko/.docker
          resources:
            requests:
              memory: "1Gi"
              cpu: "500m"
            limits:
              memory: "3Gi"
              cpu: "2"
      volumes:
        - name: build-context
          hostPath:
            path: ${CONTEXT_DIR}
            type: Directory
        - name: docker-config
          secret:
            secretName: kaniko-docker-config
      restartPolicy: Never
EOF

# ── Stream build logs ──────────────────────────────────────────
echo "▶ Waiting for build pod..."

# Wait for the pod to exist
POD=""
for _ in $(seq 1 60); do
  POD=$(kubectl get pods -l "job-name=${JOB_NAME}" -n "$NAMESPACE" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
  if [ -n "$POD" ]; then
    break
  fi
  sleep 2
done

if [ -z "$POD" ]; then
  echo "✗ Build pod never appeared!"
  rm -rf "$CONTEXT_DIR"
  exit 1
fi

# Wait for the container to be running (past ContainerCreating)
echo "▶ Waiting for container to start..."
for _ in $(seq 1 60); do
  PHASE=$(kubectl get pod "$POD" -n "$NAMESPACE" -o jsonpath='{.status.containerStatuses[0].state}' 2>/dev/null || true)
  if [[ "$PHASE" == *"running"* ]] || [[ "$PHASE" == *"terminated"* ]]; then
    break
  fi
  sleep 2
done

# Stream logs — follows until completion
echo ""
echo "▶ Build output:"
echo ""
kubectl logs -f "$POD" -n "$NAMESPACE" 2>&1
echo ""

# ── Check result ───────────────────────────────────────────────
kubectl wait --for=condition=complete --timeout=30s "job/${JOB_NAME}" -n "$NAMESPACE" 2>/dev/null || true
STATUS=$(kubectl get job "$JOB_NAME" -n "$NAMESPACE" -o jsonpath='{.status.succeeded}')
if [ "$STATUS" != "1" ]; then
  echo "✗ Build failed!"
  rm -rf "$CONTEXT_DIR"
  exit 1
fi

# ── Deploy ──────────────────────────────────────────────────────
if [ -f "${CONTEXT_DIR}/${HELM_VALUES}" ]; then
  # ── Helm deploy ──────────────────────────────────────────────
  echo "▶ Deploying with Helm..."
  helm upgrade --install "$SAFE_NAME" "$CHART_PATH" \
    -f "${CONTEXT_DIR}/${HELM_VALUES}" \
    --set image.tag="$TAG" \
    -n "$NAMESPACE" 2>&1

  DEPLOY_NAME=$(grep '^name:' "${CONTEXT_DIR}/${HELM_VALUES}" | awk '{print $2}' | tr -d "\"'")
  DEPLOY_NAME="${DEPLOY_NAME:-$SAFE_NAME}"
  echo "▶ Waiting for rollout..."
  for _ in $(seq 1 15); do
    if kubectl get deployment "$DEPLOY_NAME" -n "$NAMESPACE" &>/dev/null; then
      break
    fi
    sleep 2
  done
  kubectl rollout status "deployment/${DEPLOY_NAME}" -n "$NAMESPACE" --timeout=120s 2>&1
  prune_old_images

elif [ -d "${CONTEXT_DIR}/k8s" ]; then
  # ── Legacy kubectl deploy ────────────────────────────────────
  echo "▶ Applying k8s/ manifests..."
  kubectl apply -f "${CONTEXT_DIR}/k8s/" -n "$NAMESPACE" 2>&1

  # Find the deployment name
  DEPLOY_NAME=""
  for name in "$APP_NAME" "$SAFE_NAME"; do
    if kubectl get deployment "$name" -n "$NAMESPACE" &>/dev/null; then
      DEPLOY_NAME="$name"
      break
    fi
  done

  if [ -z "$DEPLOY_NAME" ] && [ -d "${CONTEXT_DIR}/k8s" ]; then
    # shellcheck disable=SC1083
    DEPLOY_NAME=$(grep -rl 'kind: Deployment' "${CONTEXT_DIR}/k8s/" | head -1 | xargs grep 'name:' | head -1 | awk '{print $2}')
    if [ -n "$DEPLOY_NAME" ] && ! kubectl get deployment "$DEPLOY_NAME" -n "$NAMESPACE" &>/dev/null; then
      DEPLOY_NAME=""
    fi
  fi

  if [ -z "$DEPLOY_NAME" ]; then
    echo "⚠ No deployment found — image built and pushed, but no rollout performed."
    echo "  Create a deployment manually or add helm-values.yaml to your project."
    rm -rf "$CONTEXT_DIR"
    exit 0
  fi

  # shellcheck disable=SC1083
  CONTAINER_NAME=$(kubectl get deployment "$DEPLOY_NAME" -n "$NAMESPACE" \
    -o jsonpath='{.spec.template.spec.containers[0].name}')

  echo "▶ Rolling out ${APP_NAME} (deployment/${DEPLOY_NAME})..."
  kubectl set image "deployment/${DEPLOY_NAME}" "${CONTAINER_NAME}=${IMAGE}" -n "$NAMESPACE" 2>&1
  kubectl rollout status "deployment/${DEPLOY_NAME}" -n "$NAMESPACE" --timeout=120s 2>&1
  prune_old_images

else
  echo "⚠ No ${HELM_VALUES} or k8s/ directory found — image built and pushed, but no deploy performed."
  rm -rf "$CONTEXT_DIR"
  exit 0
fi

# ── Clean up ───────────────────────────────────────────────────
rm -rf "$CONTEXT_DIR"

# ── Print result ───────────────────────────────────────────────
# shellcheck disable=SC1083
HOSTS=$(kubectl get ingress -n "$NAMESPACE" -l "app=${DEPLOY_NAME}" -o jsonpath='{.items[*].spec.rules[*].host}' 2>/dev/null)
if [ -z "$HOSTS" ]; then
  HOSTS=$(kubectl get ingress -n "$NAMESPACE" -o jsonpath="{.items[?(@.metadata.name==\"${DEPLOY_NAME}\")].spec.rules[*].host}" 2>/dev/null)
fi

echo "${APP_NAME} deployed → ${IMAGE}"
echo ""
if [ -n "$HOSTS" ]; then
  for HOST in $HOSTS; do
    echo "✅ https://${HOST}"
  done
fi
echo ""
